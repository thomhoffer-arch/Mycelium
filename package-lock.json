{
  "name": "Mycelium",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "workspaces": [
        "packages/*",
        "connectors/*"
      ]
    },
    "connectors/example-bcf": {
      "name": "mycelium-example-bcf",
      "version": "0.1.0",
      "dependencies": {
        "mycelium-sdk": "*"
      }
    },
    "connectors/example-email": {
      "name": "mycelium-example-email",
      "version": "0.1.0",
      "dependencies": {
        "mycelium-sdk": "*"
      }
    },
    "connectors/example-erpnext": {
      "name": "mycelium-example-erpnext",
      "version": "0.1.0",
      "dependencies": {
        "mycelium-sdk": "*"
      }
    },
    "connectors/reference-connector": {
      "name": "mycelium-reference-connector",
      "version": "0.1.0",
      "dependencies": {
        "mycelium-sdk": "*"
      }
    },
    "node_modules/mycelium-example-bcf": {
      "resolved": "connectors/example-bcf",
      "link": true
    },
    "node_modules/mycelium-example-email": {
      "resolved": "connectors/example-email",
      "link": true
    },
    "node_modules/mycelium-example-erpnext": {
      "resolved": "connectors/example-erpnext",
      "link": true
    },
    "node_modules/mycelium-reference-connector": {
      "resolved": "connectors/reference-connector",
      "link": true
    },
    "node_modules/mycelium-sdk": {
      "resolved": "packages/mycelium-sdk",
      "link": true
    },
    "packages/mycelium-sdk": {
      "version": "0.1.0",
      "license": "Apache-2.0",
      "engines": {
        "node": ">=18"
      }
    }
  }
}
